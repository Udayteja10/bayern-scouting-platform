# ============================================================
# FC Bayern Munich — Club Intelligence Platform
# Copy this file to .env and fill in your values
# ============================================================

# --- Database ---
MYSQL_DATABASE=fcbayern_db
MYSQL_USER=fcbayern
MYSQL_PASSWORD=fcbayern_pass
MYSQL_ROOT_PASSWORD=root_pass

# --- JWT ---
JWT_SECRET=fcbayern_super_secret_jwt_key_2024_enterprise_platform_v1
JWT_EXPIRATION_MS=86400000

# --- Sportmonks API ---
# Get your key at: https://sportmonks.com/
SPORTMONKS_API_KEY=your_sportmonks_api_key_here

# --- Default Admin User (seeded on first boot) ---
ADMIN_EMAIL=admin@fcbayern.de
ADMIN_PASSWORD=Bayern2024!
